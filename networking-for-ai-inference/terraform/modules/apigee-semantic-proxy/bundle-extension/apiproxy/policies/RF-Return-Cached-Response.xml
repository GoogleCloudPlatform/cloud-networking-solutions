<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<RaiseFault async="false" continueOnError="false" enabled="true" name="RF-Return-Cached-Response">
  <DisplayName>Return Cached Response</DisplayName>
  <Properties/>
  <FaultResponse>
    <Set>
      <StatusCode>200</StatusCode>
      <ReasonPhrase>OK</ReasonPhrase>
      <Headers>
        <Header name="Content-Type">application/json</Header>
        <Header name="X-Cache-Status">HIT</Header>
        <Header name="X-Cache-Key">{semanticcache.SCL-Semantic-Cache-Lookup.cachekey}</Header>
      </Headers>
      <Payload contentType="application/json">{semanticcache.SCL-Semantic-Cache-Lookup.cachedvalue}</Payload>
    </Set>
  </FaultResponse>
  <IgnoreUnresolvedVariables>true</IgnoreUnresolvedVariables>
</RaiseFault>
