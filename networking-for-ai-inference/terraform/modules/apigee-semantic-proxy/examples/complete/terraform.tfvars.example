# Example terraform.tfvars file
# Copy this to terraform.tfvars and fill in your values

proxy_name          = "semantic-cache"
apigee_organization = "my-org"
apigee_environment  = "prod"

region         = "us-east4"
project_id     = "my-project-id"
project_number = "123456789012"

index_endpoint_id            = "8365159230910496768"
deployed_index_id            = "semantic_cache_deployed"
index_id                     = "3600759843478044672"
vertex_ai_endpoint_subdomain = "69696451"

backend_target = "http://35.212.102.181"

# Optional: Customize cache behavior
similarity_threshold = 0.95
cache_ttl_seconds    = 60
